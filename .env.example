# ─────────────────────────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_SECRET_KEY=<valor aleatorio largo, ej: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://*.onrender.com
#
# POSTGRES_DB=<Database del servicio PostgreSQL>
# POSTGRES_USER=<Username del servicio PostgreSQL>
# POSTGRES_PASSWORD=<Password del servicio PostgreSQL>
# POSTGRES_HOST=<Hostname interno del servicio PostgreSQL, NO "db">
# POSTGRES_PORT=5432
#
# CELERY_BROKER_URL=<URL de un Redis real>
# CELERY_RESULT_BACKEND=<misma URL u otra DB del mismo Redis>
#
# EMAIL_HOST=<SMTP real>
# EMAIL_PORT=587
# EMAIL_HOST_USER=<usuario SMTP real>
# EMAIL_HOST_PASSWORD=<clave SMTP real>
# EMAIL_USE_TLS=True
#
# OLLAMA_BASE_URL=<URL del servidor Ollama>
# OLLAMA_MODEL=qwen2.5:3b
#
# Opcional: si se definen, el Dockerfile crea este superusuario una sola vez
# al arrancar (idempotente, no rompe deploys siguientes). Si se omiten, no
# se crea ningún superusuario automáticamente.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@dyxersoft.com
# DJANGO_SUPERUSER_PASSWORD=<clave segura, elegida por vos>
